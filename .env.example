# Server Configuration
PORT=5000
NODE_ENV=development

# Cloudflare R2 Configuration
CF_REGION=auto
CF_BUCKET_NAME=files
CF_BUCKET_DOMAIN=files.giftedtech.co.ke
CF_ACCESS_KEY_ID=your_cloudflare_access_key_id_here
CF_SECRET_ACCESS_KEY=your_cloudflare_secret_access_key_here
CF_BUCKET_API_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare Turnstile (CAPTCHA)
CF_TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
CF_TURNSTILE_API_URL=https://challenges.cloudflare.com

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/gifted-cdn

# Telegram Bot Configuration (Optional - for contact form)
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here
TELEGRAM_API_URL=https://api.telegram.org

# Allowed MIME Types (Optional - defaults are provided in config.js)
# IMAGE_MIMETYPES=['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp', 'image/svg+xml', 'image/avif', 'image/heif', 'image/heic', 'image/x-icon', 'image/tiff']
